{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "types": ["react"]
  },
  "include": ["src"],
  "exclude": ["src/**/*.stories.ts", "src/**/*.stories.tsx"]
}
