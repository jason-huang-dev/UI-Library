{
  "name": "jason-ui-library",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo build",
    "build:tokens": "pnpm --filter @jason-ui/tokens build",
    "build:ui": "pnpm --filter @jason-ui/ui build",
    "build:docs": "pnpm --filter docs build-storybook",
    "vercel-build": "pnpm build:tokens && pnpm build:ui && pnpm build:docs"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  }
}